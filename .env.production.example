# Copy to .env.production before: npm run release / scripts/deploy-prod-dell.sh --backoffice
# Vite production builds load this over .env — keep .env as Steve-local (localhost).

# Dell electroPOS API (LAN preferred for AppImage on shop machines)
VITE_API_BASE_URL=http://192.168.1.10:4000/api

# Steve invoice intake (AI box) — must be reachable from Dell
VITE_INVOICE_INTAKE_URL=http://192.168.1.13:4101
VITE_INVOICE_INTAKE_API_KEY=change-me-same-as-steve-intake
